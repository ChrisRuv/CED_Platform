<div class="full-screen-bg" style="background: url('{{{ config.wwwroot }}}/theme/image.php?theme=ced&component=theme&image=ced-hero') no-repeat center center; background-size: cover;">
  
    <div class="top-nav">
        <button id="open-login-btn" class="top-login-btn">
            <span class="icon">👤</span> Ingresar
        </button>
    </div>

    <!-- Modal Overlay -->
    <div id="login-modal" class="modal-overlay">
        <div class="modal-container">
            <button id="close-login-btn" class="modal-close-btn">&times;</button>
            
            <div class="login-modal-inner">
                <!-- Branding Logo -->
                <div class="modal-logo">
                    <div class="ced-logo-text">
                        <span class="ced-c">C</span>
                        <span class="ced-rest">ED</span>
                    </div>
                    <div class="platform-subtitle">PLATAFORMA EDUCATIVA</div>
                </div>

                <div class="moodle-form-wrapper">
                    {{{ output.main_content }}}
                </div>


                <div class="login-footer">
                    <p>Al ingresar, confirmas que has leído y aceptado el <a href="#">aviso de privacidad</a>.</p>
                    <div class="welearning-logo">
                        <span class="we-text">we</span>learning
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        var openBtn = document.getElementById('open-login-btn');
        var closeBtn = document.getElementById('close-login-btn');
        var modal = document.getElementById('login-modal');

        if(openBtn && closeBtn && modal) {
            openBtn.addEventListener('click', function() {
                modal.classList.add('active');
            });

            closeBtn.addEventListener('click', function() {
                modal.classList.remove('active');
            });

            // Close on click outside
            window.addEventListener('click', function(e) {
                if (e.target === modal) {
                    modal.classList.remove('active');
                }
            });
        }
    });
</script>
